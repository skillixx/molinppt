# Moling platform (required in production)
# 1) MOLING_API_BASE_URL: Moling API base URL, e.g. https://moling.example.com
# 2) INTERNAL_API_TOKEN: Internal token with /api/internal/* permission
MOLING_API_BASE_URL=
INTERNAL_API_TOKEN=
LOCAL_MOLING_MOCK=false
# Local mock values are used only when LOCAL_MOLING_MOCK=true
LOCAL_MOLING_USER_ID=
LOCAL_MOLING_ENTITLEMENT_ID=
LOCAL_MOLING_INITIAL_CREDITS=

# Test-only credentials. Do not commit real account values.
TEST_ACCOUNT=
TEST_PASSWORD=

# Application runtime
APP_ENV=development
APP_PORT=5177
APP_BASE_URL=
# Moling identifiers used to validate launch tickets / select balances
MOLING_APP_ID=
MOLING_PRODUCT_ID=
# Temporary multi-user fallback when Moling has not deployed
# GET /api/internal/user-entitlements yet. Format: user_id:entitlement_id,user_id:entitlement_id
MOLING_USER_ENTITLEMENT_MAP=
# Single entitlement fallback for local smoke tests or controlled single-user demos only.
# Leave empty in multi-user production unless you intentionally want one fixed entitlement.
MOLING_DEFAULT_ENTITLEMENT_ID=
SESSION_TTL_SECONDS=
SESSION_COOKIE_SECURE=

# Compatibility aliases for Moling deployment commands.
PORT=
PPT_APP_ID=
PPT_PRODUCT_ID=
PPT_DEFAULT_ENTITLEMENT_ID=

# Database
DATABASE_URL=
STORAGE_DIR=

# Object storage
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# AI providers
# For DeepSeek chat-completions use:
# LLM_PROVIDER=http
# LLM_API_URL=https://api.deepseek.com/chat/completions
# LLM_API_KEY=<provider token>
# LLM_MODEL=deepseek-v4-flash
LLM_PROVIDER=
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=
LLM_MAX_RETRIES=
IMAGE_PROVIDER=
IMAGE_API_KEY=
